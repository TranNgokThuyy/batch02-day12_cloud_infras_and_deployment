# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# App
APP_NAME=Lab09 RAG Chatbot API
APP_VERSION=1.0.0

# RAG / LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.05
WEAVIATE_COLLECTION=RAGDocument
# Optional: set these only when using Weaviate instead of local_index.json
WEAVIATE_URL=
WEAVIATE_API_KEY=
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
# Optional reranker/PageIndex integrations
JINA_API_KEY=
PAGEINDEX_API_KEY=
PAGEINDEX_DOC_ID=

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# Rate & Budget
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0

# Storage
REDIS_URL=redis://localhost:6379/0
HISTORY_TTL_SECONDS=2592000

# CORS
ALLOWED_ORIGINS=http://localhost:3000
